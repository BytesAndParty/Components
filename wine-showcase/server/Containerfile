# ── Build Stage ───────────────────────────────────────────────────────────────
FROM node:22-alpine AS builder

WORKDIR /app

COPY package.json ./
RUN npm install

COPY tsconfig.json ./
COPY src ./src
RUN npm run build

# Nur Produktions-Dependencies neu installieren
RUN npm prune --omit=dev

# ── Runtime Stage ─────────────────────────────────────────────────────────────
FROM node:22-alpine

WORKDIR /app

COPY --from=builder /app/dist ./dist
COPY --from=builder /app/node_modules ./node_modules
COPY package.json ./

# Daten-Verzeichnis für Assets (wird als Volume gemountet)
RUN mkdir -p data/assets

ENV NODE_ENV=production

EXPOSE 3000
EXPOSE 3002

CMD ["node", "dist/index.js"]
