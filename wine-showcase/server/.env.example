# ── Datenbank ────────────────────────────────────────────────────────────────
# Leer lassen → SQLite (lokale Entwicklung, kein Setup nötig)
# Auf "postgres" setzen → PostgreSQL (Podman / Produktion)
DB_TYPE=

# Nur relevant wenn DB_TYPE=postgres:
DB_HOST=localhost
DB_PORT=5432
DB_NAME=wine_server
DB_USER=vendure
DB_PASSWORD=vendure_pw

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000
ADMIN_PORT=3002

# Erlaubte Origins für CORS (kommagetrennt)
CORS_ORIGINS=http://localhost:5173,http://localhost:4321

# ── Auth ─────────────────────────────────────────────────────────────────────
SUPERADMIN_USERNAME=superadmin
SUPERADMIN_PASSWORD=superadmin
COOKIE_SECRET=change-me-in-production

NODE_ENV=development
